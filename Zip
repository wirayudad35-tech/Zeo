<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
    <title>TOP UP ROBLOX INSTAN</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <style>
        body {
            font-family: 'Poppins', sans-serif;
            background: radial-gradient(circle at top, #1e293b 0%, #0f172a 45%, #020617 100%);
            color: white;
            min-height: 100vh;
        }
        .glass {
            background: rgba(30, 41, 59, 0.7);
            backdrop-filter: blur(16px);
            border: 1px solid rgba(255,255,255,0.1);
        }
    </style>
</head>

<body class="flex items-center justify-center p-4">
    <div class="w-full max-w-sm">
        <!-- HEADER -->
        <div class="text-center mb-8">
            <div class="w-20 h-20 mx-auto bg-white rounded-2xl p-2 mb-4 shadow-xl flex items-center justify-center">
                <img src="https://upload.wikimedia.org/wikipedia/commons/7/7e/Roblox_Logo_2022.jpg" class="w-full h-auto">
            </div>
            <h1 class="text-3xl font-bold tracking-tight">TOP UP <span class="text-green-400">ROBLOX</span></h1>
            <p class="text-slate-400 text-sm mt-1">Proses otomatis • Cepat • Aman</p>
        </div>

        <!-- FORM ORDER -->
        <div class="glass rounded-3xl p-6 shadow-2xl" id="orderForm">
            <div class="bg-gradient-to-r from-green-500 to-emerald-600 p-4 rounded-2xl mb-6 shadow-lg shadow-green-900/20">
                <h2 class="font-bold text-lg text-white">🔥 PROMO TERBATAS</h2>
                <p class="text-xs text-white/90">Top up Robux dengan harga terbaik!</p>
            </div>

            <div class="space-y-3 mb-6">
                <div class="bg-slate-950/50 border border-slate-700 p-4 rounded-xl flex justify-between items-center">
                    <div>
                        <h3 class="font-bold text-sm">500 ROBUX</h3>
                        <p class="text-[10px] text-slate-400 uppercase">Instan</p>
                    </div>
                    <span class="text-green-400 font-bold">Rp60.000</span>
                </div>
                <div class="bg-slate-950/50 border border-slate-700 p-4 rounded-xl flex justify-between items-center">
                    <div>
                        <h3 class="font-bold text-sm">1000 ROBUX</h3>
                        <p class="text-[10px] text-slate-400 uppercase">Best Seller</p>
                    </div>
                    <span class="text-green-400 font-bold">Rp105.000</span>
                </div>
            </div>

            <div class="space-y-4">
                <div>
                    <label class="text-xs text-slate-400 ml-1">Username Roblox</label>
                    <input type="text" id="username" placeholder="Masukkan username" class="w-full mt-1 p-3 bg-slate-950 border border-slate-700 rounded-xl focus:ring-2 focus:ring-green-500 outline-none transition-all">
                </div>
                <div>
                    <label class="text-xs text-slate-400 ml-1">Pilih Paket</label>
                    <select id="paket" class="w-full mt-1 p-3 bg-slate-950 border border-slate-700 rounded-xl focus:ring-2 focus:ring-green-500 outline-none transition-all">
                        <option value="500 ROBUX - Rp60.000">500 ROBUX - Rp60.000</option>
                        <option value="1000 ROBUX - Rp105.000">1000 ROBUX - Rp105.000</option>
                    </select>
                </div>
            </div>

            <button onclick="orderNow()" class="w-full mt-6 p-4 rounded-xl bg-green-500 hover:bg-green-600 font-bold text-white transition-all shadow-lg shadow-green-500/30">
                LANJUT PEMBAYARAN 🚀
            </button>
            <p id="errorMsg" class="text-red-400 text-xs mt-3 text-center hidden">Username harus diisi!</p>
        </div>

        <!-- PAYMENT -->
        <div class="glass rounded-3xl p-6 shadow-2xl hidden" id="payment">
            <h2 class="text-xl font-bold text-center mb-6">Pembayaran DANA</h2>
            <div class="bg-slate-950 border border-slate-700 rounded-xl p-4 mb-4">
                <div class="flex justify-between py-1"><span class="text-slate-400 text-sm">User</span><span id="showUser" class="font-medium"></span></div>
                <div class="flex justify-between py-1"><span class="text-slate-400 text-sm">Paket</span><span id="showPaket" class="font-medium text-green-400"></span></div>
            </div>

            <div class="bg-slate-800 border border-slate-600 p-4 rounded-2xl text-center mb-4">
                <p class="text-slate-300 text-xs mb-1">Transfer DANA ke:</p>
                <div class="bg-black/40 p-2 rounded-lg border border-blue-500/30">
                    <p class="text-xl font-bold text-blue-400 tracking-wider">085862940936</p>
                </div>
                <p class="text-slate-400 text-[10px] mt-1 font-semibold">A/N: SONY DIRGANTARA</p>
            </div>

            <!-- UPLOAD BUKTI -->
            <div class="mb-6">
                <label class="text-xs text-slate-400 ml-1">Unggah Bukti Transfer</label>
                <input type="file" id="buktiTransfer" accept="image/*" class="w-full mt-1 p-2 bg-slate-950 border border-slate-700 rounded-xl text-xs text-slate-300 focus:ring-2 focus:ring-green-500 outline-none">
            </div>

            <button onclick="finishOrder()" class="w-full p-4 rounded-xl bg-green-500 font-bold hover:bg-green-600 transition-all">
                SAYA SUDAH BAYAR ✅
            </button>
            <p id="errorBukti" class="text-red-400 text-xs mt-2 text-center hidden">Mohon unggah bukti pembayaran!</p>
        </div>

        <!-- DONE -->
        <div class="glass rounded-3xl p-8 text-center hidden" id="done">
            <div class="w-16 h-16 bg-green-500/20 rounded-full flex items-center justify-center mx-auto mb-4">
                <span class="text-3xl">✅</span>
            </div>
            <h2 class="text-2xl font-bold mb-2">Berhasil!</h2>
            <p class="text-slate-400 text-sm mb-6">Bukti pembayaran telah diterima. Order sedang diproses dalam 1-5 menit.</p>
            <button onclick="location.reload()" class="text-slate-400 text-sm hover:text-white underline transition-all">Kembali ke beranda</button>
        </div>
    </div>

    <script>
        function orderNow() {
            let user = document.getElementById("username").value;
            let paket = document.getElementById("paket").value;
            let error = document.getElementById("errorMsg");
            if(user === "") { error.classList.remove("hidden"); return; }
            error.classList.add("hidden");
            document.getElementById("showUser").innerText = user;
            document.getElementById("showPaket").innerText = paket;
            document.getElementById("orderForm").classList.add("hidden");
            document.getElementById("payment").classList.remove("hidden");
        }
        function finishOrder() {
            let bukti = document.getElementById("buktiTransfer").files.length;
            let errorBukti = document.getElementById("errorBukti");
            
            if(bukti === 0) {
                errorBukti.classList.remove("hidden");
                return;
            }
            
            document.getElementById("payment").classList.add("hidden");
            document.getElementById("done").classList.remove("hidden");
        }
    </script>
</body>
</html>
